<!doctype html>
<html lang="zh-CN">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ site_title }} · 历史日报</title>
<style>
  :root { --bg: #f6f7f9; --card: #fff; --text: #1a1d21; --muted: #6b7280; --accent: #2563eb; --border: #e5e7eb; }
  @media (prefers-color-scheme: dark) {
    :root { --bg: #101216; --card: #1a1e24; --text: #e7e9ec; --muted: #9aa1ab; --accent: #7aa5f8; --border: #2a2f37; }
  }
  * { box-sizing: border-box; margin: 0; }
  body { background: var(--bg); color: var(--text); font: 16px/1.65 -apple-system, "PingFang SC", sans-serif; }
  .wrap { max-width: 720px; margin: 0 auto; padding: 16px 14px 48px; }
  header { display: flex; align-items: baseline; justify-content: space-between; padding: 8px 2px 20px; }
  header h1 { font-size: 20px; }
  header a { color: var(--muted); font-size: 14px; text-decoration: none; }
  ul { list-style: none; }
  li a {
    display: block; background: var(--card); border: 1px solid var(--border);
    border-radius: 12px; padding: 12px 16px; margin-bottom: 10px;
    color: var(--accent); font-weight: 600; text-decoration: none;
  }
</style>
</head>
<body>
<div class="wrap">
  <header>
    <h1>历史日报</h1>
    <a href="index.html">‹ 最新</a>
  </header>
  <ul>
    {% for d in dates %}<li><a href="{{ d }}.html">{{ d }}</a></li>{% endfor %}
  </ul>
</div>
</body>
</html>
